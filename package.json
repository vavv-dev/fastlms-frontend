{
  "name": "fastlms-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "upgrade": "npx npm-check-updates -u -x '/^eslint$/'",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,css,scss,md}'",
    "codemod:import": "npx @mui/codemod@latest v5.0.0/top-level-imports src/**/*.ts*",
    "openapi:generate": "openapi-ts",
    "i18n:extract": "i18next-scanner --config .i18next-scanner.config.cjs",
    "prepare": "husky",
    "test": "echo \"No test yet. TODO\" && exit 1",
    "generate_source_file": "bash ./script/generate_source_file.sh"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@fontsource/roboto": "^5.1.0",
    "@hookform/resolvers": "^3.9.0",
    "@mui/icons-material": "^6.1.2",
    "@mui/material": "^6.1.2",
    "@mui/x-charts": "^7.18.0",
    "@tiptap/core": "^2.8.0",
    "@tiptap/extension-color": "^2.8.0",
    "@tiptap/extension-heading": "^2.8.0",
    "@tiptap/extension-highlight": "^2.8.0",
    "@tiptap/extension-image": "^2.8.0",
    "@tiptap/extension-link": "^2.8.0",
    "@tiptap/extension-placeholder": "^2.8.0",
    "@tiptap/extension-strike": "^2.8.0",
    "@tiptap/extension-subscript": "^2.8.0",
    "@tiptap/extension-superscript": "^2.8.0",
    "@tiptap/extension-table": "^2.8.0",
    "@tiptap/extension-table-cell": "^2.8.0",
    "@tiptap/extension-table-header": "^2.8.0",
    "@tiptap/extension-table-row": "^2.8.0",
    "@tiptap/extension-task-item": "^2.8.0",
    "@tiptap/extension-task-list": "^2.8.0",
    "@tiptap/extension-text-style": "^2.8.0",
    "@tiptap/extension-underline": "^2.8.0",
    "@tiptap/pm": "^2.8.0",
    "@tiptap/react": "^2.8.0",
    "@tiptap/starter-kit": "^2.8.0",
    "@uppy/aws-s3": "^4.1.0",
    "@uppy/dashboard": "^4.1.0",
    "@uppy/drag-drop": "^4.0.2",
    "@uppy/file-input": "^4.0.1",
    "@uppy/progress-bar": "^4.0.0",
    "@uppy/react": "^4.0.2",
    "emoji-picker-react": "^4.12.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "jotai": "^2.10.0",
    "lodash": "^4.17.21",
    "mui-tiptap": "^1.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^15.0.2",
    "react-movable": "^3.3.1",
    "react-player": "^2.16.0",
    "react-rewards": "^2.0.4",
    "react-router-dom": "^6.26.2",
    "swr": "^2.2.5",
    "tiptap-extension-resize-image": "^1.1.9",
    "webvtt-parser": "^2.2.0",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.53.7",
    "@types/lodash": "^4.17.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react-swc": "^3.7.1",
    "babel-plugin-import": "^1.13.8",
    "eslint": "8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "husky": "^9.1.6",
    "i18next-scanner": "^4.5.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rollup": "^4.24.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-node-polyfills": "^0.22.0"
  },
  "lint-staged": {
    "!(src/api/**/*).{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(src/api/**/*).{json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
